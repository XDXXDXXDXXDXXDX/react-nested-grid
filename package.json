{
  "name": "react-nested-grid",
  "version": "1.0.3",
  "description": "A lightweight React component for rendering JSON-driven nested grid layouts.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": true,
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && tsc-alias --dir dist",
    "clean": "rm -rf dist",
    "dev": "vite --host 127.0.0.1",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write",
    "lint": "biome check",
    "prepublishOnly": "npm run typecheck && npm run build",
    "pub": "npm version patch && npm publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,css,json,md}": "biome check --write --no-errors-on-unmatched"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/XDXXDXXDXXDXXDX/react-nested-grid"
  },
  "keywords": [
    "react",
    "nested",
    "grid",
    "layout",
    "tree",
    "json",
    "css-grid",
    "dashboard",
    "data-driven",
    "declarative",
    "component",
    "visualization",
    "layer",
    "hierarchy",
    "lite",
    "css"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "react-dom": "^18.3.1",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}

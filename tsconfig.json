{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2019"],
    "strict": true,
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "react-nested-grid": ["./src/index.ts"],
      "src/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "rootDir": "src"
  },
  "include": ["src", "test"]
}

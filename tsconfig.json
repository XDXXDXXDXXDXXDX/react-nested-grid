{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2019"],
    "strict": true,
    "paths": {
      "react-nested-grid": ["./src/index.ts"],
      "src/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./dist",
    "rootDir": "src"
  },
  "include": ["src"]
}
